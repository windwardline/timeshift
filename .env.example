# Copy real values into gitignored files — never commit secrets.
#   - DATABASE_URL goes in .env       (Prisma CLI reads it from there)
#   - everything else goes in .env.local (read server-side only)

# Postgres connection string (Prisma).
DATABASE_URL="postgresql://USER@localhost:5432/timeshift?schema=public"

# AI provider key — Google AI Studio (Gemini). Default model chain falls through
# on a rate limit: gemini-3.1-flash-lite → 2.5-flash-lite → 2.0-flash-lite →
# 3.5-flash → 2.5-flash. Override with GEMINI_MODELS (comma-separated).
GEMINI_API_KEY=""
GEMINI_MODELS=""

# Passwordless magic-link login (Resend).
RESEND_API_KEY=""
# From address for sign-in emails (must be a verified Resend domain).
MAGIC_LINK_FROM="TimeShift <login@windwardline.com>"
# Canonical app origin used to build magic links (e.g. the deployed URL).
APP_URL=""
