# Copy real values into gitignored files — never commit secrets.
#   - DATABASE_URL goes in .env       (Prisma CLI reads it from there)
#   - the AI key goes in .env.local   (read server-side only, never sent to the browser)

# Postgres connection string (Prisma).
DATABASE_URL="postgresql://USER@localhost:5432/timeshift?schema=public"

# AI provider key. OpenAI is the active provider (docs/AI_ADVICE.md). Put the
# real key in .env.local. Tests and coverage run with no key present.
OPENAI_API_KEY=""

# Optional: override the chat model (default: gpt-4o-mini).
OPENAI_MODEL=""
