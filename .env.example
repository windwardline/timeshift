# Copy real values into gitignored files — never commit secrets.
#   - DATABASE_URL goes in .env       (Prisma CLI reads it from there)
#   - the AI key goes in .env.local   (read server-side only, never sent to the browser)

# Postgres connection string (Prisma).
DATABASE_URL="postgresql://USER@localhost:5432/timeshift?schema=public"

# AI provider key. Google AI Studio (Gemini) is the active provider
# (docs/AI_ADVICE.md). Put the real key in .env.local. Tests run with no key.
GEMINI_API_KEY=""

# Optional: override the model fallback chain (comma-separated, fastest first).
# Default chain falls through on any provider error (e.g. a rate limit):
#   gemini-3.1-flash-lite, gemini-2.5-flash-lite, gemini-2.0-flash-lite,
#   gemini-3.5-flash, gemini-2.5-flash
GEMINI_MODELS=""
